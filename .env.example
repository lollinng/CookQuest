# CookQuest Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL
POSTGRES_USER=cookquest
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=cookquest

# Redis
REDIS_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000

# API URL (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:3003/api/v1

# Node environment
NODE_ENV=development

# Domain (production only — used by Nginx reverse proxy)
DOMAIN=cookquest.app
